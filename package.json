{
  "name": "codex-start",
  "version": "1.1.8",
  "description": "Interactive TUI manager for Codex API profiles",
  "type": "module",
  "bin": {
    "cs": "dist/app.js",
    "codex-start": "dist/app.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "dev": "tsx src/app.tsx",
    "build": "tsup && chmod +x dist/app.js",
    "start": "node dist/app.js",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "cfonts": "^3.3.1",
    "ink": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.0.9",
    "omelette": "^0.4.17",
    "react": "^18.3.1",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/omelette": "^0.4.5",
    "@types/react": "^18.3.12",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
